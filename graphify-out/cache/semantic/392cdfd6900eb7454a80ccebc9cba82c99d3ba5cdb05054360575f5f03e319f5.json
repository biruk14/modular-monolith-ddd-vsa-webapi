{"nodes": [{"id": "split_deployment_poc_md", "label": "Split-Deployment PoC Documentation", "file_type": "document", "source_file": "docs/split-deployment-poc.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "concept_cross_process_masstransit", "label": "Cross-Process MassTransit Request/Response via RabbitMQ", "file_type": "rationale", "source_file": "docs/split-deployment-poc.md", "source_location": "### Cross-process call path", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Products instance sends GetSeedUserIdsRequest via MassTransit RabbitMQ exchange; IAM instance picks up from queue and responds via reply queue. No HTTP. No shared in-process memory. Pure message-passing. TraceId propagated by MassTransit across both processes."}, {"id": "concept_outbox_skip_locked", "label": "Outbox SELECT FOR UPDATE SKIP LOCKED Concurrency", "file_type": "rationale", "source_file": "docs/split-deployment-poc.md", "source_location": "## Concurrent safety", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Multiple OutboxProcessor instances claim disjoint row batches via SELECT FOR UPDATE SKIP LOCKED, preventing duplicate publishing when multiple processes run the same outbox infrastructure."}, {"id": "concept_hangfire_distributed_queue", "label": "Hangfire Postgres Distributed Queue", "file_type": "rationale", "source_file": "docs/split-deployment-poc.md", "source_location": "## Concurrent safety", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Postgres-backed Hangfire queue ensures only one server executes each job. Two Hangfire servers provide active/active failover, not duplicate execution. BackgroundJobsOptions__IsServer=false excludes instances from job execution."}, {"id": "concept_probe_cross_module_endpoint", "label": "GET /v1/probe/cross-module Endpoint", "file_type": "do